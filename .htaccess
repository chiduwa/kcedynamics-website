# ═══════════════════════════════════════════════
#  KCE Dynamics Limited — Apache / Hostinger config
#  Handles: HTTPS, www→non-www, caching, security
# ═══════════════════════════════════════════════

Options -Indexes
RewriteEngine On

# ── 1. Force HTTPS ──────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── 2. www → non-www (canonical) ────────────────
RewriteCond %{HTTP_HOST} ^www\.kcedynamics\.com [NC]
RewriteRule ^(.*)$ https://kcedynamics.com/$1 [L,R=301]

# ── 2b. /index.html → / (canonical home URL) ────
RewriteRule ^index\.html$ / [R=301,L]

# ── 2c. /favicon.ico → svg favicon ──────────────
RewriteRule ^favicon\.ico$ /assets/images/favicon.svg [R=302,L]

# ── 2d. Legacy pre-launch placeholder URLs → current pages ──
# These paths belonged to the Hostinger placeholder site that ran
# before this site went live and are still known to Google (404 in
# Search Console). Redirect instead of leaving them dangling so any
# existing links/index entries carry over to the real page.
RewriteRule ^maintenance-page/?$ / [R=301,L]
RewriteRule ^contact-us/?$ /contact.html [R=301,L]
RewriteRule ^services/?$ /services.html [R=301,L]
RewriteRule ^projects/?$ /projects.html [R=301,L]

# ── 3. Security headers ──────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options   "nosniff"
  Header always set X-Frame-Options          "SAMEORIGIN"
  Header always set X-XSS-Protection         "1; mode=block"
  Header always set Referrer-Policy          "strict-origin-when-cross-origin"
  Header always set Permissions-Policy       "camera=(), microphone=(), geolocation=(self)"
  # Remove server signature
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# ── 4. Browser caching (long TTL on versioned assets) ──
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — short cache (content changes occasionally)
  ExpiresByType text/html                    "access plus 4 hours"

  # CSS + JS — long cache (filename-based versioning)
  ExpiresByType text/css                     "access plus 1 year"
  ExpiresByType application/javascript       "access plus 1 year"
  ExpiresByType text/javascript              "access plus 1 year"

  # Images & vector
  ExpiresByType image/jpeg                   "access plus 1 year"
  ExpiresByType image/png                    "access plus 1 year"
  ExpiresByType image/webp                   "access plus 1 year"
  ExpiresByType image/svg+xml                "access plus 1 year"
  ExpiresByType image/x-icon                 "access plus 1 year"
  ExpiresByType image/gif                    "access plus 1 year"

  # Fonts
  ExpiresByType font/woff                    "access plus 1 year"
  ExpiresByType font/woff2                   "access plus 1 year"
  ExpiresByType application/font-woff        "access plus 1 year"
  ExpiresByType application/font-woff2       "access plus 1 year"

  # Video
  ExpiresByType video/mp4                    "access plus 6 months"
  ExpiresByType video/webm                   "access plus 6 months"

  # Data
  ExpiresByType application/json             "access plus 0 seconds"
  ExpiresByType application/ld+json          "access plus 0 seconds"
  ExpiresByType text/xml                     "access plus 1 week"
</IfModule>

# ── 5. Gzip / Brotli compression ────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/ld+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE application/xml
</IfModule>

# ── 6. Custom error pages ────────────────────────
ErrorDocument 404 /404.html
ErrorDocument 403 /index.html
